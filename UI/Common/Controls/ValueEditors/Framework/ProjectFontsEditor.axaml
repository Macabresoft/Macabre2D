<common:ValueEditorControl xmlns="https://github.com/avaloniaui"
                           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                           xmlns:framework="clr-namespace:Macabre2D.Framework;assembly=Macabre2D.Framework"
                           xmlns:local="clr-namespace:Macabre2D.UI.Common"
                           xmlns:avaloniaEx="clr-namespace:Macabresoft.AvaloniaEx;assembly=Macabresoft.AvaloniaEx"
                           xmlns:common="clr-namespace:Macabre2D.UI.Common;assembly=Macabre2D.UI.Common"
                           x:TypeArguments="framework:ProjectFonts"
                           x:Class="Macabre2D.UI.Common.ProjectFontsEditor">
    <Grid ColumnDefinitions="Auto, *"
          RowDefinitions="Auto, Auto, Auto"
          DataContext="{Binding $parent[local:ProjectFontsEditor]}">
        <Design.DataContext>
            <local:ProjectFontsEditor />
        </Design.DataContext>
        
        <TextBlock Grid.Column="0"
                   Grid.Row="0"
                   Classes="Label"
                   Text="Culture" />
        
        <ComboBox Grid.Column="1"
                  Grid.Row="0"
                  ItemsSource="{Binding AvailableCultures, Mode=OneTime}"
                  SelectedItem="{Binding CurrentCulture}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock HorizontalAlignment="Stretch"
                               Text="{Binding Converter={x:Static local:ToDisplayNameConverter.Instance}}"
                               TextAlignment="Left"
                               ToolTip.Tip="{Binding}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        
        <Border Grid.Column="0"
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Classes="HorizontalSeparator" />
        
        <ItemsControl Grid.Column="0"
                      Grid.Row="2"
                      Grid.ColumnSpan="2"
                      ItemsSource="{Binding FontsInCurrentCulture, Mode=OneWay}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="Auto, *, Auto, Auto"
                          RowDefinitions="Auto, Auto, Auto, Auto">
                        <TextBlock Grid.Column="0"
                                   Grid.ColumnSpan="4"
                                   Grid.Row="0"
                                   FontWeight="Bold"
                                   Text="{Binding Category, Converter={x:Static local:ToDisplayNameConverter.Instance}}" />
                        
                        <!-- Sprite Sheet Font -->
                        <TextBlock Grid.Column="0"
                                   Grid.Row="1"
                                   Classes="Label"
                                   FontWeight="Normal"
                                   Text="Sprite Sheet Font: " />

                        <TextBox Grid.Column="1"
                                 Grid.Row="1"
                                 IsReadOnly="True"
                                 VerticalAlignment="Top"
                                 Text="{Binding SpriteSheetFontPath}"
                                 ToolTip.Tip="{Binding SpriteSheetFontPath}" />

                        <Button Grid.Column="2"
                                Grid.Row="1"
                                VerticalAlignment="Top"
                                Classes="Icon"
                                Command="{Binding $parent[local:ProjectFontsEditor].SelectSpriteSheetFontCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Search for a sprite sheet font">
                            <avaloniaEx:Icon Content="{StaticResource DocumentSearchIcon}" />
                        </Button>
                        <Button Grid.Column="3"
                                Grid.Row="1"
                                VerticalAlignment="Top"
                                Classes="Icon"
                                Command="{Binding $parent[local:ProjectFontsEditor].ClearSpriteSheetFontCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Clear the sprite sheet font">
                            <avaloniaEx:Icon Content="{StaticResource EraserIcon}" />
                        </Button>
                        
                        <!-- MonoGame Font -->
                        <TextBlock Grid.Column="0"
                                   Grid.Row="2"
                                   Classes="Label"
                                   FontWeight="Normal"
                                   Text="MonoGame Font: " />

                        <TextBox Grid.Column="1"
                                 Grid.Row="2"
                                 IsReadOnly="True"
                                 VerticalAlignment="Top"
                                 Text="{Binding MonoGameFontPath}"
                                 ToolTip.Tip="{Binding MonoGameFontPath}" />

                        <Button Grid.Column="2"
                                Grid.Row="2"
                                VerticalAlignment="Top"
                                Classes="Icon"
                                Command="{Binding $parent[local:ProjectFontsEditor].SelectMonoGameFontCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Search for a MonoGame font">
                            <avaloniaEx:Icon Content="{StaticResource DocumentSearchIcon}" />
                        </Button>
                        <Button Grid.Column="3"
                                Grid.Row="2"
                                VerticalAlignment="Top"
                                Classes="Icon"
                                Command="{Binding $parent[local:ProjectFontsEditor].ClearMonoGameFontCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Clear the MonoGame font">
                            <avaloniaEx:Icon Content="{StaticResource EraserIcon}" />
                        </Button>
                        
                        <Border Grid.Column="0"
                                Grid.Row="3"
                                Grid.ColumnSpan="4"
                                Classes="HorizontalSeparator" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</common:ValueEditorControl>